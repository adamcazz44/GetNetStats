/* ===========================================================
   GetNetStats — premium dark dashboard theme
   Geist (UI) + Geist Mono (data). Cool near-black + cyan.
   =========================================================== */
:root {
  --bg:        #070b12;
  --bg-grad:   radial-gradient(120% 80% at 50% -10%, #0d1a2c 0%, #080d16 48%, #05070c 100%);
  --panel:     rgba(255,255,255,0.028);
  --panel-2:   rgba(255,255,255,0.05);
  --border:    rgba(255,255,255,0.07);
  --border-2:  rgba(255,255,255,0.12);
  --text:      #e6edf5;
  --muted:     #8a99ad;
  --dim:       #6f8096;
  --faint:     #4a5a70;
  --accent:    #22d3ee;
  --accent-2:  #5fe6f7;
  --accent-dim:#46b8cc;
  --good:      #34d399;
  --warn:      #fbbf24;
  --bad:       #f87171;
  --r-lg: 20px; --r-md: 14px; --r-sm: 10px;
  --maxw: 1240px;
  --sans: "Geist", system-ui, -apple-system, sans-serif;
  --mono: "Spline Sans Mono", ui-monospace, "SF Mono", monospace;
}

* { box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  margin: 0;
  background: var(--bg);
  color: var(--text);
  font-family: var(--sans);
  -webkit-font-smoothing: antialiased;
  line-height: 1.5;
}
.mono { font-family: var(--mono); font-feature-settings: "tnum" 1, "zero" 1; }
a { color: inherit; text-decoration: none; }
.wrap { max-width: var(--maxw); margin: 0 auto; padding: 0 28px; }

/* ---------- header ---------- */
header.site {
  position: sticky; top: 0; z-index: 50;
  backdrop-filter: blur(14px);
  background: rgba(7,11,18,0.72);
  border-bottom: 1px solid var(--border);
}
.site .bar { display: flex; align-items: center; justify-content: space-between; height: 64px; }
.brand { display: flex; align-items: center; gap: 11px; font-weight: 600; letter-spacing: -0.02em; font-size: 17px; }
.brand .dot { width: 11px; height: 11px; border-radius: 3px; background: #ffffff; box-shadow: 0 0 14px rgba(255,255,255,0.5); }
.brand b { font-weight: 600; } .brand b span { color: var(--accent-2); }
nav.main { display: flex; gap: 28px; font-size: 14.5px; color: var(--muted); }
nav.main a { transition: color .15s; } nav.main a:hover { color: var(--text); }
.status-pill { display: inline-flex; align-items: center; gap: 8px; border-radius: 999px; font-size: 12.5px; font-weight: 500;
  padding: 7px 13px; background: rgba(34,211,238,0.1); color: var(--accent-2); border: 1px solid rgba(34,211,238,0.25); font-family: var(--mono); }
.status-pill .led { width: 7px; height: 7px; border-radius: 50%; background: var(--good); box-shadow: 0 0 8px var(--good); }
.status-pill.scanning { background: rgba(251,191,36,0.1); color: var(--warn); border-color: rgba(251,191,36,0.28); }
.status-pill.scanning .led { background: var(--warn); box-shadow: 0 0 8px var(--warn); animation: blink 1s steps(2) infinite; }
@keyframes blink { 50% { opacity: 0.25; } }

/* ---------- hero / tool ---------- */
/* Aurora fade: pure CSS radial gradients (no images, no blur filter, no animation) */
.hero { position: relative; padding: 40px 0 56px;
  background:
    radial-gradient(46% 60% at 16% -4%, rgba(124,92,255,0.20) 0%, transparent 60%),
    radial-gradient(44% 56% at 78% 4%, rgba(34,211,238,0.18) 0%, transparent 62%),
    radial-gradient(38% 48% at 50% -8%, rgba(236,72,153,0.12) 0%, transparent 58%),
    var(--bg-grad); }
.hero-grid { display: grid; grid-template-columns: 1fr 300px; gap: 28px; }
.stage {
  position: relative; border-radius: var(--r-lg);
  background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(255,255,255,0));
  border: 1px solid var(--border); padding: 30px;
  display: grid; grid-template-columns: 1.04fr 0.96fr; gap: 26px; align-items: center;
}
.lede { font-family: var(--mono); font-size: 12.5px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent-dim); }
.stage-controls { position: absolute; top: 30px; right: 30px; z-index: 4; display: flex; flex-direction: column; align-items: flex-end; gap: 10px; }
.conn-pill { display: inline-flex; align-items: center; gap: 8px; font-family: var(--mono); font-size: 12.5px; font-weight: 500;
  padding: 7px 13px; border-radius: 999px; background: rgba(34,211,238,0.1); color: var(--accent-2); border: 1px solid rgba(34,211,238,0.25); }
.conn-pill .led { width: 7px; height: 7px; border-radius: 50%; background: var(--good); box-shadow: 0 0 8px var(--good); }
.conn-pill.wait { background: rgba(251,191,36,0.1); color: var(--warn); border-color: rgba(251,191,36,0.28); }
.conn-pill.wait .led { background: var(--warn); box-shadow: 0 0 8px var(--warn); animation: blink 1s steps(2) infinite; }
.conn-pill.bad { background: rgba(248,113,113,0.1); color: var(--bad); border-color: rgba(248,113,113,0.3); }
.conn-pill.bad .led { background: var(--bad); box-shadow: 0 0 8px var(--bad); }
.rerun-pill { flex: 0 0 auto; display: inline-flex; align-items: center; gap: 8px; cursor: pointer; font-family: var(--mono);
  font-size: 12.5px; font-weight: 500; letter-spacing: 0.03em; padding: 8px 14px; border-radius: 999px;
  background: rgba(34,211,238,0.1); color: var(--accent-2); border: 1px solid rgba(34,211,238,0.28);
  transition: background .15s, border-color .15s, transform .08s; }
.rerun-pill:hover { background: rgba(34,211,238,0.18); border-color: rgba(34,211,238,0.5); }
.rerun-pill:active { transform: scale(0.96); }
.rerun-pill:disabled { opacity: 0.6; cursor: default; }
.rerun-pill svg { width: 14px; height: 14px; }
.rerun-pill:disabled svg { animation: spin 1s linear infinite; }
h1.headline { font-size: clamp(30px, 3.4vw, 44px); line-height: 1.04; letter-spacing: -0.03em; margin: 14px 0 0; font-weight: 600; text-wrap: balance; }
h1.headline em { font-style: normal; color: var(--accent-2); }
.subhead { color: var(--muted); font-size: 15.5px; line-height: 1.55; margin-top: 14px; max-width: 42ch; }

/* IP feature row */
.ip-row { margin-top: 22px; display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
.ip-box { display: flex; align-items: center; gap: 14px; background: rgba(255,255,255,0.03); border: 1px solid var(--border);
  border-radius: var(--r-md); padding: 13px 16px; min-width: 0; }
.ip-box .k { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--dim); }
.ip-box .ip { font-family: var(--mono); font-size: clamp(20px, 2.4vw, 27px); font-weight: 600; line-height: 1.1; letter-spacing: -0.01em; }
.ip-box .meta { font-size: 12.5px; color: var(--muted); margin-top: 3px; }
.ip-box .meta .ver { font-family: var(--mono); color: var(--accent-2); }
.copy-btn { flex: 0 0 auto; display: inline-flex; align-items: center; gap: 7px; cursor: pointer; border: 1px solid var(--border-2);
  background: rgba(255,255,255,0.04); color: var(--text); border-radius: var(--r-sm); padding: 9px 13px; font-family: var(--mono);
  font-size: 12.5px; font-weight: 500; transition: background .15s, border-color .15s, transform .08s; }
.copy-btn:hover { background: rgba(34,211,238,0.12); border-color: rgba(34,211,238,0.4); }
.copy-btn:active { transform: scale(0.96); }
.copy-btn.copied { color: var(--good); border-color: rgba(52,211,153,0.5); background: rgba(52,211,153,0.12); }
.copy-btn svg { width: 14px; height: 14px; }

/* readout grid (ping / upload / connection / quality) */
.readouts { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 16px; }
.ro { background: rgba(255,255,255,0.028); border: 1px solid var(--border); border-radius: var(--r-md); padding: 13px 15px; min-height: 78px; }
.ro .k { font-family: var(--mono); font-size: 10.5px; letter-spacing: 0.13em; text-transform: uppercase; color: var(--dim); display: flex; align-items: center; gap: 6px; }
.ro .v { font-family: var(--mono); font-size: 23px; font-weight: 600; margin-top: 6px; line-height: 1.1; letter-spacing: -0.01em; }
.ro .v small { font-size: 12px; color: var(--dim); font-weight: 400; letter-spacing: 0; }
.ro .v.txt { font-size: 18px; }
.ro .sub { font-size: 11.5px; color: var(--muted); margin-top: 3px; }

/* signal bars */
.sigbars { display: flex; align-items: flex-end; gap: 4px; height: 22px; margin-top: 7px; }
.sigbars i { width: 7px; border-radius: 2px; background: var(--good); display: block; transition: opacity .25s, background .25s; }
.sigbars i.off { background: var(--dim); opacity: 0.3; }
.q-good { color: var(--good); } .q-fair { color: var(--warn); } .q-bad { color: var(--bad); }

/* reveal animation */
.reveal { opacity: 0; transform: translateY(8px); transition: opacity .5s ease, transform .5s cubic-bezier(.2,.7,.3,1); }
.reveal.in { opacity: 1; transform: none; }

/* ---------- radar ---------- */
.radar-wrap { display: flex; flex-direction: column; align-items: center; gap: 18px; }
.radar { position: relative; width: 100%; max-width: 320px; aspect-ratio: 1; border-radius: 50%;
  background: radial-gradient(circle, rgba(34,211,238,0.06), rgba(34,211,238,0) 70%); }
.radar .ring { position: absolute; inset: 0; border-radius: 50%; border: 1px solid rgba(34,211,238,0.15); }
.radar .ring.r2 { inset: 17%; } .radar .ring.r3 { inset: 34%; } .radar .ring.r4 { inset: 51%; }
.radar .cross, .radar .crossv { position: absolute; background: rgba(34,211,238,0.1); }
.radar .cross { left: 0; right: 0; top: 50%; height: 1px; }
.radar .crossv { top: 0; bottom: 0; left: 50%; width: 1px; }
.radar .sweep { position: absolute; inset: 0; border-radius: 50%; opacity: 0.5; animation: spin 6s linear infinite;
  background: conic-gradient(from 0deg, rgba(34,211,238,0.5), rgba(34,211,238,0) 55deg); }
.radar.scanning .sweep { opacity: 1; animation: spin 2.2s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
.radar .blip { position: absolute; width: 9px; height: 9px; border-radius: 50%; background: var(--accent-2);
  box-shadow: 0 0 12px var(--accent-2); top: 33%; left: 63%; opacity: 0; transition: opacity .4s; }
.radar.done .blip { opacity: 1; animation: ping-blip 2s ease-out infinite; }
@keyframes ping-blip { 0% { box-shadow: 0 0 0 0 rgba(95,230,247,0.5); } 100% { box-shadow: 0 0 0 16px rgba(95,230,247,0); } }
.radar .progress-ring { position: absolute; inset: -2px; transform: rotate(-90deg); }
.radar .center { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; }
.radar .center .big { font-family: var(--mono); font-size: clamp(38px, 5vw, 52px); font-weight: 700; line-height: 1; letter-spacing: -0.02em; }
/* signal-strength readout inside the radar */
.radar .center .sig { display: flex; align-items: flex-end; gap: 6px; height: 48px; margin-bottom: 9px; }
.radar .center .sig i { width: 9px; border-radius: 3px; background-color: var(--good); opacity: 1; transition: opacity .35s ease, background-color .35s ease, height .35s cubic-bezier(.2,.7,.3,1); }
.radar .center .sig i.off { background: var(--dim); opacity: 0.22; }
.radar .center .sig.q-good i:not(.off) { background: var(--good); opacity: 1; }
.radar .center .sig.q-fair i:not(.off) { background: var(--warn); opacity: 1; }
.radar .center .sig.q-bad i:not(.off) { background: var(--bad); opacity: 1; }
.radar .center .big-sig { font-family: var(--sans); font-size: clamp(24px, 3.2vw, 33px); font-weight: 500; line-height: 1; letter-spacing: -0.015em; }
.radar .center .lbl { font-family: var(--mono); font-size: 11px; letter-spacing: 0.15em; text-transform: uppercase; color: var(--dim); margin-top: 7px; }
.radar .center .phase { font-family: var(--mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent-dim); margin-top: 4px; min-height: 14px; }

/* run button */
.run-btn { display: inline-flex; align-items: center; justify-content: center; gap: 9px; cursor: pointer; border: none;
  background: linear-gradient(180deg, #2ddbf5, #16b6d6); color: #04222a; font-family: var(--sans); font-weight: 600; font-size: 15px;
  padding: 13px 26px; border-radius: 999px; box-shadow: 0 6px 22px rgba(34,211,238,0.3); transition: transform .1s, box-shadow .2s, opacity .2s; }
.run-btn:hover { box-shadow: 0 8px 30px rgba(34,211,238,0.45); }
.run-btn:active { transform: scale(0.97); }
.run-btn:disabled { opacity: 0.55; cursor: default; box-shadow: none; }
.run-btn svg { width: 17px; height: 17px; }

/* ---------- ad rail ---------- */
.rail { display: flex; flex-direction: column; gap: 14px; }
.ad { position: relative; display: flex; flex-direction: column; align-items: center; justify-content: center;
  border-radius: var(--r-md); background: rgba(255,255,255,0.02); border: 1px dashed rgba(255,255,255,0.13); color: var(--faint);
  background-image: repeating-linear-gradient(45deg, rgba(255,255,255,0.015) 0 10px, transparent 10px 20px); }
.ad .lab { position: absolute; top: 9px; left: 11px; font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase; font-family: var(--mono); color: var(--faint); }
.ad .big { font-family: var(--mono); font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.6; }
.ad.mrec { height: 250px; } .ad.halfpage { flex: 1; min-height: 600px; } .ad.leaderboard { height: 90px; }

/* ---------- section scaffolding ---------- */
section { padding: 56px 0; }
.eyebrow { font-family: var(--mono); font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent-dim); }
h2.sec { font-size: clamp(24px, 2.6vw, 32px); line-height: 1.1; letter-spacing: -0.025em; font-weight: 600; margin: 12px 0 0; text-wrap: balance; }
.sec-intro { color: var(--muted); font-size: 16px; line-height: 1.6; max-width: 64ch; margin: 14px 0 0; }
.divider { border: 0; border-top: 1px solid var(--border); margin: 0; }

/* how it works */
.how-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 28px; }
.how-step { background: var(--panel); border: 1px solid var(--border); border-radius: var(--r-md); padding: 24px; }
.how-n { font-size: 13px; letter-spacing: 0.12em; color: var(--accent-2); font-weight: 600; }
.how-t { font-size: 18px; font-weight: 600; letter-spacing: -0.02em; margin: 12px 0 8px; }
.how-d { font-size: 14.5px; color: var(--muted); line-height: 1.6; }

/* related tools */
.tools-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-top: 28px; }
.tool-card { display: flex; flex-direction: column; gap: 8px; background: var(--panel); border: 1px solid var(--border);
  border-radius: var(--r-md); padding: 20px; transition: border-color .18s, background .18s, transform .12s; cursor: pointer; }
.tool-card:hover { border-color: rgba(34,211,238,0.35); background: rgba(34,211,238,0.04); transform: translateY(-2px); }
.tool-card .ico { width: 38px; height: 38px; border-radius: var(--r-sm); display: flex; align-items: center; justify-content: center;
  background: rgba(34,211,238,0.1); color: var(--accent-2); border: 1px solid rgba(34,211,238,0.2); }
.tool-card .ico svg { width: 19px; height: 19px; }
.tool-card .t { font-weight: 600; font-size: 16px; letter-spacing: -0.01em; display: flex; align-items: center; gap: 7px; }
.tool-card .t .arrow { color: var(--dim); transition: transform .18s, color .18s; }
.tool-card:hover .t .arrow { transform: translate(3px,-3px); color: var(--accent-2); }
.tool-card .d { font-size: 13.5px; color: var(--muted); line-height: 1.5; }

/* content / education */
.content-grid { display: grid; grid-template-columns: 1.5fr 1fr; gap: 40px; align-items: start; margin-top: 28px; }
.prose p { color: var(--muted); font-size: 15.5px; line-height: 1.7; margin: 0 0 16px; }
.prose h3 { font-size: 20px; letter-spacing: -0.02em; margin: 30px 0 12px; font-weight: 600; }
.prose h3:first-child { margin-top: 0; }
.prose strong { color: var(--text); font-weight: 600; }
.prose a.inline { color: var(--accent-2); border-bottom: 1px solid rgba(95,230,247,0.3); }
.prose ul { margin: 0 0 16px; padding-left: 0; list-style: none; display: flex; flex-direction: column; gap: 10px; }
.prose ul li { color: var(--muted); font-size: 15px; line-height: 1.5; padding-left: 26px; position: relative; }
.prose ul li::before { content: ""; position: absolute; left: 4px; top: 9px; width: 6px; height: 6px; border-radius: 50%; background: var(--accent); }
.prose ul li b { color: var(--text); font-weight: 600; }

/* comparison table */
.cmp { width: 100%; border-collapse: collapse; border: 1px solid var(--border); border-radius: var(--r-md); overflow: hidden; font-size: 14px; }
.cmp th, .cmp td { text-align: left; padding: 13px 16px; border-bottom: 1px solid var(--border); }
.cmp thead th { font-family: var(--mono); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--dim);
  background: rgba(255,255,255,0.02); }
.cmp tbody th { font-weight: 500; color: var(--text); }
.cmp tbody td { color: var(--muted); font-family: var(--mono); font-size: 13px; }
.cmp tr:last-child th, .cmp tr:last-child td { border-bottom: 0; }
.cmp .tag { display: inline-block; font-family: var(--mono); font-size: 11px; padding: 2px 8px; border-radius: 6px; }
.cmp .tag.v4 { background: rgba(34,211,238,0.12); color: var(--accent-2); }
.cmp .tag.v6 { background: rgba(167,139,250,0.14); color: #c4b5fd; }

/* side note card */
.note-card { background: var(--panel); border: 1px solid var(--border); border-radius: var(--r-md); padding: 22px; position: sticky; top: 84px; }
.note-card h4 { font-size: 14px; margin: 0 0 10px; display: flex; align-items: center; gap: 8px; letter-spacing: -0.01em; }
.note-card h4 .d { width: 7px; height: 7px; border-radius: 50%; background: var(--warn); box-shadow: 0 0 8px var(--warn); }
.note-card p { font-size: 13.5px; color: var(--muted); line-height: 1.6; margin: 0 0 12px; }
.note-card p:last-child { margin-bottom: 0; }

/* FAQ */
.faq { display: flex; flex-direction: column; gap: 10px; margin-top: 28px; max-width: 860px; }
.faq-item { border: 1px solid var(--border); border-radius: var(--r-md); background: var(--panel); overflow: hidden; transition: border-color .18s; }
.faq-item[open] { border-color: rgba(34,211,238,0.25); }
.faq-item summary { list-style: none; cursor: pointer; padding: 18px 22px; display: flex; align-items: center; justify-content: space-between;
  gap: 16px; font-weight: 500; font-size: 16px; letter-spacing: -0.01em; }
.faq-item summary::-webkit-details-marker { display: none; }
.faq-item summary .pm { flex: 0 0 auto; width: 22px; height: 22px; position: relative; transition: transform .2s; }
.faq-item summary .pm::before, .faq-item summary .pm::after { content: ""; position: absolute; background: var(--accent-2); border-radius: 2px; }
.faq-item summary .pm::before { left: 4px; right: 4px; top: 10px; height: 2px; }
.faq-item summary .pm::after { top: 4px; bottom: 4px; left: 10px; width: 2px; transition: opacity .2s; }
.faq-item[open] summary .pm::after { opacity: 0; }
.faq-item .a { padding: 0 22px 20px; color: var(--muted); font-size: 14.5px; line-height: 1.65; }
.faq-item .a a { color: var(--accent-2); border-bottom: 1px solid rgba(95,230,247,0.3); }

/* footer */
footer.site { border-top: 1px solid var(--border); padding: 48px 0 36px; background: #05070c; }
.foot-grid { display: grid; grid-template-columns: 1.6fr 1fr 1fr 1fr; gap: 32px; }
.foot-col h5 { font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--dim); margin: 0 0 14px; }
.foot-col a { display: block; color: var(--muted); font-size: 14px; padding: 5px 0; transition: color .15s; }
.foot-col a:hover { color: var(--text); }
.foot-brand p { color: var(--muted); font-size: 14px; line-height: 1.6; margin: 14px 0 0; max-width: 34ch; }
.foot-bottom { display: flex; align-items: center; justify-content: space-between; margin-top: 40px; padding-top: 24px;
  border-top: 1px solid var(--border); color: var(--dim); font-size: 13px; flex-wrap: wrap; gap: 12px; }
.foot-bottom .mono { font-size: 12px; }

/* ---------- responsive ---------- */
@media (max-width: 1080px) {
  .hero-grid { grid-template-columns: 1fr; }
  .rail { flex-direction: row; flex-wrap: wrap; justify-content: center; gap: 16px; }
  .ad { flex: 1 1 300px; max-width: 360px; }
  .ad.halfpage { min-height: 250px; }
  .content-grid { grid-template-columns: 1fr; }
  .note-card { position: static; }
}
@media (max-width: 820px) {
  .stage { grid-template-columns: 1fr; }
  .radar-wrap { order: -1; }
  .stage-controls { position: static; order: -2; flex-direction: row; justify-content: flex-end; align-items: center; gap: 10px; margin-bottom: 2px; }
  .tools-grid { grid-template-columns: 1fr 1fr; }
  .how-grid { grid-template-columns: 1fr; }
}
@media (max-width: 720px) {
  nav.main { display: none; }
  .wrap { padding: 0 18px; }
  .stage { padding: 22px; }
  .stage-controls { top: 22px; right: 22px; }
  .readouts { grid-template-columns: 1fr 1fr; }
  .foot-grid { grid-template-columns: 1fr 1fr; }
  .rail { flex-direction: column; align-items: center; }
  .ad { width: 100%; max-width: 336px; flex: none; }
  .ad.halfpage { min-height: 250px; }
}
@media (max-width: 480px) {
  .tools-grid { grid-template-columns: 1fr; }
  .ip-row { flex-direction: column; align-items: stretch; }
  .copy-btn { justify-content: center; }
}
